# Copy this file to .env and fill in the value.
# Clash Royale developer token, created against the RoyaleAPI proxy IP.
CR_API_TOKEN=

# --- Optional overrides (sensible defaults in ingestion/config.py) ---

# API base URL. Defaults to the RoyaleAPI proxy, which resolves the dynamic-IP
# token lock. Set to https://api.clashroyale.com/v1 only if your IP is
# whitelisted directly.
CR_API_BASE_URL=https://proxy.royaleapi.dev/v1

# Where ingested JSON batches are written before upload to the UC volume.
CR_RAW_DIR=data/raw

# HTTP / rate-limit tuning.
CR_REQUEST_TIMEOUT=30
CR_MAX_RETRIES=6
CR_BACKOFF_BASE=1.0
CR_BACKOFF_CAP=60.0
CR_REQUESTS_PER_MINUTE=120

# --- Databricks (used by the upload/trigger steps in .github/workflows/daily.yml
#     and the ingestion.upload_to_databricks / trigger_databricks_job scripts) ---
# Workspace URL and a PAT scoped to Files + Jobs. Stored as GitHub secrets in CI.
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=
# Target UC volume directory for raw JSON (catalog/schema/volume).
DATABRICKS_VOLUME=/Volumes/workspace/clash/raw
# Job id of the bronze->silver->gold notebook chain to trigger after upload.
DATABRICKS_JOB_ID=1049179186835703
